PORT=3001
FRONTEND_URL=http://localhost:5173
NODE_ENV=development

# Storage configuration
STORAGE_TYPE=filesystem
STORAGE_PATH=./uploads

# Database
DATA_DIR=./data
DB_FILENAME=graphite.db

# Security
MAX_FILE_SIZE=50MB
ALLOWED_FILE_TYPES=application/pdf

# Authentication
# Optional: if omitted, Graphite will generate a persistent secret in DATA_DIR/session-secret
# SESSION_SECRET=change-me-to-a-random-string-at-least-32-characters-long
# Optional override for where the generated secret is stored
# SESSION_SECRET_FILE=./data/session-secret
# Optional override for first-run admin password (otherwise Graphite generates a random one and logs it once)
# BOOTSTRAP_ADMIN_PASSWORD=change-this-before-first-boot

# Trust proxy (set when behind nginx/traefik/etc.)
# TRUST_PROXY=1
